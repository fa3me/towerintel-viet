# Copy to .env.local and fill in (Vite exposes only VITE_* to the client).

# Supabase project (Authentication + Postgres)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Must match the email you use to sign in as app owner (gets full access + approvals UI)
VITE_OWNER_EMAIL=you@example.com

# Optional: override URL for WorldPop 1 km GeoTIFF (default: /data/vn_ppp_2020_1km_Aggregated.tif)
# VITE_WORLDPOP_TIF_URL=/data/vn_ppp_2020_1km_Aggregated.tif
